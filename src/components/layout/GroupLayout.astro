---
import AppShell from '@/components/ui/AppShell';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';
import { getGroupBySlug } from '@/lib/constants/calcs';
import '@/styles/global.css';

interface Props {
  groupSlug: string;
  calcs: import('@/lib/constants/calcs').CalcMeta[];
  page: number;
  totalPages: number;
}

const { groupSlug, page, totalPages } = Astro.props;

const group = getGroupBySlug(groupSlug);
const seo   = PAGE_SEO[groupSlug];

const baseUrl     = `${SITE.url}/${groupSlug}`;
const canonical   = page === 1 ? baseUrl : `${baseUrl}/${page}`;
const baseTitle   = seo?.title ?? `${group?.label ?? groupSlug} — ${SITE.name}`;
const title       = page === 1 ? baseTitle : baseTitle.replace(' —', ` — Página ${page} —`);
const description = seo?.description ?? group?.description ?? SITE.description;

const prevUrl = page > 1        ? (page === 2 ? `/${groupSlug}` : `/${groupSlug}/${page - 1}`) : null;
const nextUrl = page < totalPages ? `/${groupSlug}/${page + 1}` : null;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {prevUrl && <link rel="prev" href={`${SITE.url}${prevUrl}`} />}
    {nextUrl && <link rel="next" href={`${SITE.url}${nextUrl}`} />}

    <!-- Tabler Icons webfont (sidebar icons) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"
    />

    <!-- OpenGraph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name"   content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
  </head>

  <body style="margin:0;padding:0;background:#EDE8DF;">
    <AppShell client:load initialGroup={groupSlug} />
  </body>
</html>
