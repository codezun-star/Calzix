---
import Header from './Header.astro';
import Footer from './Footer.astro';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';
import { getCalcBySlug, getRelatedCalcs, getDomainGroup } from '@/lib/constants/calcs';
import '@/styles/global.css';

interface Props {
  slug: string;
  faqs?: Array<{ q: string; a: string }>;
  whatIs?: string;
  whyUse?: string;
}

const { slug, faqs = [], whatIs = '', whyUse = '' } = Astro.props;

const seo     = PAGE_SEO[slug];
const calc    = getCalcBySlug(slug);
const related = getRelatedCalcs(slug);

const title       = seo?.title       ?? `${calc?.name ?? slug} — ${SITE.name}`;
const description = seo?.description ?? calc?.description ?? SITE.description;
const canonical   = seo?.canonical   ?? `${SITE.url}/${slug}`;

const group = calc ? getDomainGroup(calc.domain) : undefined;
const breadcrumb = [
  { name: SITE.name, href: '/' },
  ...(group ? [{ name: group.label, href: `/${group.slug}` }] : []),
  { name: calc?.name ?? slug, href: canonical },
];

const faqSchema = faqs.length > 0
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    })
  : null;

const appSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: calc?.name ?? slug,
  description,
  url: canonical,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- OpenGraph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name"   content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={appSchema} />
    {faqSchema && <script is:inline type="application/ld+json" set:html={faqSchema} />}
  </head>

  <body>
    <Header />

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] mb-8" aria-label="Ruta">
        {breadcrumb.map(({ name, href }, i) => (
          <>
            {i > 0 && <span aria-hidden="true">/</span>}
            {i < breadcrumb.length - 1
              ? <a href={href} class="hover:text-[var(--color-text)] transition-colors">{name}</a>
              : <span class="text-[var(--color-text-secondary)]">{name}</span>
            }
          </>
        ))}
      </nav>

      <!-- H1 + descripción -->
      {calc && (
        <div class="mb-8">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-[var(--color-text)] leading-tight">{calc.name}</h1>
          <p class="text-[var(--color-text-secondary)] mt-2 text-lg max-w-2xl">{calc.longDescription}</p>
        </div>
      )}

      <!-- Componente React -->
      <slot />

      <!-- Contenido adicional de la página (tablas, ejemplos, guías) -->
      <slot name="extra" />

      <!-- ¿Qué es? -->
      {whatIs && (
        <section class="mt-8 p-5 bg-white rounded-xl border border-[var(--color-border)]" style="border-left: 4px solid var(--color-accent)">
          <h2 class="text-lg font-bold text-[var(--color-text)] mb-3">¿Qué es?</h2>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed" set:html={whatIs} />
        </section>
      )}

      <!-- ¿Para qué sirve? -->
      {whyUse && (
        <section class="mt-6 p-5 bg-white rounded-xl border border-[var(--color-border)]" style="border-left: 4px solid var(--color-accent)">
          <h2 class="text-lg font-bold text-[var(--color-text)] mb-3">¿Para qué sirve?</h2>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed" set:html={whyUse} />
        </section>
      )}

      <!-- Calculadoras relacionadas -->
      {related.length > 0 && (
        <section class="mt-20">
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-5">Calculadoras relacionadas</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {related.map(r => (
              <a
                href={`/${r.slug}`}
                class="group flex flex-col gap-3 rounded-2xl border border-[var(--color-calcs-border)] bg-[var(--color-surface)] p-5 transition-all hover:border-[var(--color-accent)] hover:shadow-sm"
              >
                <h3 class="text-sm font-semibold text-[var(--color-text)] leading-snug">{r.name}</h3>
                <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed line-clamp-2">{r.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- FAQs -->
      {faqs.length > 0 && (
        <section class="mt-16">
          <h2 class="text-2xl font-extrabold text-[var(--color-text)] mb-6">Preguntas frecuentes</h2>
          <dl class="space-y-4">
            {faqs.map(({ q, a }) => (
              <div class="p-5 bg-white rounded-xl border border-[var(--color-border)]">
                <dt class="font-bold text-[var(--color-text)] mb-2">{q}</dt>
                <dd class="text-[var(--color-text-secondary)] text-sm leading-relaxed">{a}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}
    </main>

    <Footer />
  </body>
</html>
