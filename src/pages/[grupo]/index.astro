---
import GroupLayout from '@/components/layout/GroupLayout.astro';
import { CALC_GROUPS, getCalcsByDomain } from '@/lib/constants/calcs';

export function getStaticPaths() {
  const PAGE_SIZE = 12;
  return CALC_GROUPS.map((group) => {
    const allCalcs = group.domains.flatMap((d) => getCalcsByDomain(d.id));
    const totalPages = Math.max(1, Math.ceil(allCalcs.length / PAGE_SIZE));
    return {
      params: { grupo: group.slug },
      props: {
        groupSlug: group.slug,
        calcs: allCalcs.slice(0, PAGE_SIZE),
        totalPages,
      },
    };
  });
}

const { groupSlug, calcs, totalPages } = Astro.props;
---

<GroupLayout groupSlug={groupSlug} calcs={calcs} page={1} totalPages={totalPages} />
