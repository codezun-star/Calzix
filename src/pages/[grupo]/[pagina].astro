---
import GroupLayout from '@/components/layout/GroupLayout.astro';
import { CALC_GROUPS, getCalcsByDomain } from '@/lib/constants/calcs';

export function getStaticPaths() {
  const PAGE_SIZE = 12;
  const paths = [];
  for (const group of CALC_GROUPS) {
    const allCalcs = group.domains.flatMap((d) => getCalcsByDomain(d.id));
    const totalPages = Math.ceil(allCalcs.length / PAGE_SIZE);
    for (let p = 2; p <= totalPages; p++) {
      paths.push({
        params: { grupo: group.slug, pagina: String(p) },
        props: {
          groupSlug: group.slug,
          calcs: allCalcs.slice((p - 1) * PAGE_SIZE, p * PAGE_SIZE),
          page: p,
          totalPages,
        },
      });
    }
  }
  return paths;
}

const { groupSlug, calcs, page, totalPages } = Astro.props;
---

<GroupLayout groupSlug={groupSlug} calcs={calcs} page={page} totalPages={totalPages} />
