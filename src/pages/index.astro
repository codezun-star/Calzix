---
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import HomeCalcs from '@/components/ui/HomeCalcs';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';
import '@/styles/global.css';

const seo = PAGE_SEO.home;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="monetag" content="9ca0907e42e5335f11365db777da534e" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- OpenGraph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={seo.canonical} />
    <meta property="og:title"       content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:site_name"   content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={seo.title} />
    <meta name="twitter:description" content={seo.description} />

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: SITE.name,
      description: SITE.description,
      url: SITE.url,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    })} />
  </head>

  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0A1E14 0%, #0D2B1A 60%, #0F3820 100%);">
        <div class="absolute bottom-0 left-0 right-0 h-24" style="background: linear-gradient(to bottom, transparent, var(--color-bg))"></div>

        <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-28">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/15 border border-white/25 text-white text-sm font-medium mb-6">
                100% gratis · Sin registro · Sin límites
              </div>
              <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-[1.1] tracking-tight">
                Calculadoras<br />
                <span style="color: #6EE09A;">online gratuitas</span>
              </h1>
              <p class="mt-5 text-lg text-white/80 leading-relaxed max-w-lg">
                Más de 100 calculadoras de matemáticas, ciencias, conversión, hogar, trabajo y más. Resultados al instante.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href="#matematicas" class="px-6 py-3 rounded-xl font-semibold text-white transition-colors shadow-lg" style="background: var(--color-accent);">
                  Ver calculadoras
                </a>
                <a href="/calculadora-hipoteca" class="px-6 py-3 rounded-xl border border-white/30 font-semibold text-white hover:bg-white/10 transition-colors">
                  Calculadora de hipoteca
                </a>
              </div>
            </div>

            <div class="hidden lg:flex items-center justify-center">
              <div class="relative w-full max-w-sm">
                <div class="absolute inset-0 bg-white/10 rounded-3xl rotate-3 border border-white/20"></div>
                <div class="relative bg-white rounded-2xl border border-white/50 p-6 shadow-2xl">
                  <div class="flex items-center gap-2 mb-4">
                    <div class="w-3 h-3 rounded-full bg-red-400"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400"></div>
                    <span class="ml-2 text-xs text-[var(--color-text-muted)] font-mono">calzix.com</span>
                  </div>
                  <div class="space-y-2">
                    {[
                      { label: 'Hipoteca 200.000 €', sub: 'Cuota: 891 €/mes' },
                      { label: 'IVA 21% sobre 500 €', sub: 'Total: 605,00 €' },
                      { label: 'IMC — 70 kg / 1,75 m', sub: 'IMC: 22,9 — Normal' },
                    ].map(item => (
                      <div class="flex items-center gap-3 p-2.5 bg-[var(--color-calcs-bg)] rounded-lg">
                        <div>
                          <p class="text-xs font-medium text-[var(--color-text)]">{item.label}</p>
                          <p class="text-xs text-[var(--color-text-secondary)]">{item.sub}</p>
                        </div>
                        <div class="ml-auto w-2 h-2 rounded-full bg-green-400"></div>
                      </div>
                    ))}
                  </div>
                  <div class="mt-4 p-2.5 rounded-lg border text-center" style="background: var(--color-accent-bg); border-color: var(--color-calcs-border);">
                    <p class="text-xs font-medium" style="color: var(--color-accent);">Cálculos al instante, sin registro</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Trust bar -->
      <div class="border-y border-[var(--color-border)] bg-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4">
          <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10 text-sm font-medium text-[var(--color-text-secondary)]">
            <span>Sin registro</span>
            <span>Sin publicidad intrusiva</span>
            <span>Gratis para siempre</span>
          </div>
        </div>
      </div>

      <!-- Calculadoras con tabs -->
      <div id="calculadoras">
        <HomeCalcs client:load />
      </div>

      <!-- CTA bottom -->
      <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20 text-center">
        <h2 class="text-3xl font-extrabold text-[var(--color-text)]">Todo gratis, para siempre</h2>
        <p class="mt-3 text-[var(--color-text-secondary)] max-w-md mx-auto">
          Sin descargas, sin registro. Resultados al instante directamente en tu navegador.
        </p>
        <a href="/calculadora-hipoteca" class="inline-flex items-center gap-2 mt-8 px-8 py-3.5 rounded-xl text-white font-semibold transition-colors" style="background: var(--color-accent);">
          Empezar a calcular
        </a>
      </section>
    </main>

    <Footer />

    <script is:inline>
      const GROUPS = ['matematicas','ciencias','conversion','hogar','trabajo','educacion','viaje','naturaleza','ocio'];

      function scrollToCalcs() {
        const hash = location.hash.slice(1);
        if (GROUPS.includes(hash)) {
          const el = document.getElementById('calculadoras');
          if (el) {
            const top = el.getBoundingClientRect().top + window.scrollY - 80;
            window.scrollTo({ top, behavior: 'smooth' });
          }
        }
      }

      window.addEventListener('hashchange', scrollToCalcs);

      if (GROUPS.includes(location.hash.slice(1))) {
        window.addEventListener('load', () => setTimeout(scrollToCalcs, 120));
      }
    </script>
  </body>
</html>
