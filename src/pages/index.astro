---
import AppShell from '@/components/ui/AppShell';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';
import '@/styles/global.css';

const seo = PAGE_SEO.home;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="monetag" content="9ca0907e42e5335f11365db777da534e" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Tabler Icons webfont (sidebar icons) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"
    />

    <!-- OpenGraph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={seo.canonical} />
    <meta property="og:title"       content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:site_name"   content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={seo.title} />
    <meta name="twitter:description" content={seo.description} />

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: SITE.name,
      description: SITE.description,
      url: SITE.url,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    })} />
  </head>

  <body style="margin:0;padding:0;background:#EDE8DF;">
    <AppShell client:load initialGroup="matematicas" />
    <script is:inline>(function(s){s.dataset.zone='11095273',s.src='https://al5sm.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>
    <script is:inline src="https://pl29628921.effectivecpmnetwork.com/0c/d5/92/0cd5925857a97ed12dca3ed7b1c4cf8a.js"></script>
  </body>
</html>
