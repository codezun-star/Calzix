---
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CalcGrid from '@/components/ui/CalcGrid';
import { CALC_GROUPS, CALCS } from '@/lib/constants/calcs';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';
import '@/styles/global.css';

const group = CALC_GROUPS.find(g => g.slug === 'ciencias')!;
const domainIds = new Set(group.domains.map(d => d.id));
const count = CALCS.filter(c => domainIds.has(c.domain)).length;
const seo = PAGE_SEO['ciencias'];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="monetag" content="9ca0907e42e5335f11365db777da534e" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <Header />

    <div class="bg-[var(--color-text)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
        <nav class="flex items-center gap-2 text-xs text-[var(--color-text-muted)] mb-6">
          <a href="/" class="hover:text-white transition-colors">Inicio</a>
          <span>/</span>
          <span style="color: var(--color-accent);">{group.label}</span>
        </nav>
        <div class="flex items-start justify-between gap-6 flex-wrap">
          <div>
            <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-3">
              Calculadoras de {group.label}
            </h1>
            <p class="text-[var(--color-text-muted)] text-base max-w-xl leading-relaxed">
              {group.description}
            </p>
          </div>
          <div class="shrink-0 self-start">
            <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-sm font-medium text-white">
              {count} calculadoras
            </span>
          </div>
        </div>
      </div>
    </div>

    <main class="bg-[var(--color-calcs-bg)] border-b border-[var(--color-calcs-border)] py-10 min-h-[60vh]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <CalcGrid groupSlug="ciencias" client:load />
      </div>
    </main>

    <Footer />
  </body>
</html>
